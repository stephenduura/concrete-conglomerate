# SMTP Mail Server Configuration
# Rename this file to '.env' and populate the values below with your Hostinger settings.

# SMTP Server details (Hostinger settings)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contact@concreteconglomerate.com
SMTP_PASS=your_hostinger_email_password

# Target inbox that will receive form submissions (e.g., your business email)
SMTP_RECEIVER=contact@concreteconglomerate.com

# Form sender address (Must match the SMTP_USER/authenticated email for Hostinger)
SMTP_SENDER="Concrete Website Enquiry" <contact@concreteconglomerate.com>
